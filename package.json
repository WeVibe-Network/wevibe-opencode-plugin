{
  "name": "wevibe-opencode-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "WeVibe Network plugin bundle for OpenCode.",
  "repository": {
    "type": "git",
    "url": "https://github.com/WeVibe-Network/wevibe-opencode-plugin.git"
  },
  "license": "Apache-2.0",
  "main": "plugins/wevibe-plugin.ts",
  "bin": {
    "wevibe-install-opencode": "bin/install-opencode.ts"
  },
  "files": [
    "bin",
    "plugins/wevibe-plugin.ts",
    "tui.json",
    "tui"
  ],
  "scripts": {
